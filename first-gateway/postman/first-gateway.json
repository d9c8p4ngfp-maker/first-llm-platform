{
  "info": {
    "name": "first-gateway",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminToken", "value": "" },
    { "key": "apiKey", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "groupId", "value": "1" },
    { "key": "channelId", "value": "1" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Admin Login",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('adminToken', json.access_token);"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\"username\":\"admin\",\"password\":\"admin123\"}" },
        "url": "{{baseUrl}}/api/v1/auth/login"
      }
    },
    {
      "name": "Create API Key",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "const json = pm.response.json();",
            "pm.collectionVariables.set('apiKey', json.key);"
          ]
        }
      }],
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/admin/tokens?tenantId=1&userId=1&name=cursor"
      }
    },
    {
      "name": "List Models",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
        "url": "{{baseUrl}}/v1/models"
      }
    },
    {
      "name": "Chat Completions",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"deepseek-chat\",\n  \"messages\": [{\"role\": \"user\", \"content\": \"hello\"}]\n}"
        },
        "url": "{{baseUrl}}/v1/chat/completions"
      }
    },
    {
      "name": "Embeddings",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{apiKey}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"text-embedding-3-small\",\n  \"input\": \"hello world\"\n}"
        },
        "url": "{{baseUrl}}/v1/embeddings"
      }
    },
    {
      "name": "Revoke API Key",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/admin/tokens/1"
      }
    },
    {
      "name": "User Management",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Create User",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "pm.collectionVariables.set('userId', json.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"username\":\"testuser\",\"password\":\"pass123\",\"email\":\"test@example.com\"}" },
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"email\":\"updated@example.com\"}" },
            "url": "{{baseUrl}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"status\":\"DISABLED\"}" },
            "url": "{{baseUrl}}/admin/users/{{userId}}/status"
          }
        },
        {
          "name": "Adjust User Quota",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"totalTokens\":200000}" },
            "url": "{{baseUrl}}/admin/users/{{userId}}/quota"
          }
        }
      ]
    },
    {
      "name": "User Groups",
      "item": [
        {
          "name": "List Groups",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/user-groups"
          }
        },
        {
          "name": "Create Group",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "pm.collectionVariables.set('groupId', json.id);"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"vip\",\"ratio\":0.5}" },
            "url": "{{baseUrl}}/admin/user-groups"
          }
        },
        {
          "name": "Update Group",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\":\"vip-plus\",\"ratio\":0.4}" },
            "url": "{{baseUrl}}/admin/user-groups/{{groupId}}"
          }
        },
        {
          "name": "Delete Group",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/user-groups/{{groupId}}"
          }
        }
      ]
    },
    {
      "name": "Redemption",
      "item": [
        {
          "name": "Batch Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"count\":5,\"amount\":10000}" },
            "url": "{{baseUrl}}/admin/redemption-codes/batch"
          }
        },
        {
          "name": "List Codes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/redemption-codes"
          }
        },
        {
          "name": "Redeem Code",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"code\":\"REPLACE_WITH_CODE\"}" },
            "url": "{{baseUrl}}/admin/redemption-codes/redeem"
          }
        }
      ]
    },
    {
      "name": "Logs and Stats",
      "item": [
        {
          "name": "Query Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/logs?page=0&size=20"
          }
        },
        {
          "name": "Daily Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/stats/daily?startDate=2026-01-01&endDate=2026-12-31"
          }
        }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "Get Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/settings"
          }
        },
        {
          "name": "Update Settings",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"channel_fail_threshold\":\"5\"}" },
            "url": "{{baseUrl}}/admin/settings"
          }
        }
      ]
    },
    {
      "name": "Channel Test",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/admin/channels/{{channelId}}/test"
      }
    }
  ]
}