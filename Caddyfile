# Caddyfile — Auto HTTPS with Let's Encrypt
# Domain is injected via env var at container start

{$DOMAIN:openfirst.cn} {
    # ACME email for Let's Encrypt
    email {$CADDY_ACME_EMAIL:admin@localhost.local}

    # API traffic → Spring Boot gateway
    handle /api/* {
        reverse_proxy gateway:8080
    }
    handle /v1/* {
        reverse_proxy gateway:8080
    }
    handle /v3/* {
        reverse_proxy gateway:8080
    }

    # WebSocket → gateway
    handle /ws/* {
        reverse_proxy gateway:8080
    }

    # All other traffic → React frontend (nginx serves SPA)
    handle {
        reverse_proxy frontend:80
    }

    # Common headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        -Server
    }
}
